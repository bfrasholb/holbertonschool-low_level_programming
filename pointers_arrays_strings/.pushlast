#!/bin/bash

FILE=$(find . -type f -not -path "*/.git/*" -printf "%T@ %p\n" \
| sort -nr \
| head -n 1 \
| cut -d' ' -f2-)

echo "Last modified file: $FILE"

git add "$FILE"
git commit -m "Autoupdate"

while true; do

read -r -p "Push $FILE to GitHub? (y/n): " CONFIRM

CONFIRM=$(echo "$CONFIRM" | tr '[:upper:]' '[:lower:]' | tr -d '[:space:]')

if [[ "$CONFIRM" == "y" || "$CONFIRM" == "yes" ]]; then
    git push origin master
    echo "$FILE pushed to repo."
    break
elif [[ "$CONFIRM" == "n" || "$CONFIRM" == "no" ]]; then
    git reset "$FILE"
    echo "$FILE unstaged, nothing will be pushed."
    break
else
    echo "Please answer Yes or No."
        fi

done
